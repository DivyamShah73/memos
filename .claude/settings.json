{
  "$comment": "Copy to .claude/settings.json in the new memos repo. Pre-allows safe, repetitive dev commands so you avoid approval fatigue during the 3-4 day build, while keeping destructive ops gated. Tune to taste.",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm add:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm db:migrate:*)",
      "Bash(pnpm db:seed:*)",
      "Bash(pnpm dev:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(vitest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b:*)",
      "Bash(curl -s http://localhost:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(docker compose down -v:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(drizzle-kit drop:*)",
      "Bash(psql:*DROP*)"
    ]
  },
  "env": {
    "$comment": "Real secrets go in .env (gitignored), not here. These are non-secret defaults.",
    "MEMOS_LOG_LEVEL": "debug"
  }
}
