# Normalize line endings so the bash phase scripts run under Git Bash on Windows.
# core.autocrlf=true on this machine would otherwise check out *.sh with CRLF,
# which Git Bash rejects ($'\r': command not found). Force LF on shell + SQL.
* text=auto eol=lf

*.sh    text eol=lf
*.sql   text eol=lf
Dockerfile text eol=lf

# Windows-native scripts keep CRLF.
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary/asset types: never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
